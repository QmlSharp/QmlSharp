<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <QmlSharpRepoRoot Condition="'$(QmlSharpRepoRoot)' == ''">$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', '..', '..', '..'))</QmlSharpRepoRoot>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(QmlSharpRepoRoot)/src/QmlSharp.Core/QmlSharp.Core.csproj" />
    <ProjectReference Include="$(QmlSharpRepoRoot)/src/QmlSharp.Dsl/QmlSharp.Dsl.csproj" />
  </ItemGroup>
</Project>
