{
  "name": "DevToolsCounterFlow",
  "version": "1.0.0",
  "entry": "./src/Program.cs",
  "outDir": "./dist",
  "qt": {
    "dir": "__QT_DIR__",
    "modules": [
      "QtQuick",
      "QtQuick.Controls"
    ]
  },
  "build": {
    "format": false,
    "lint": false,
    "sourceMaps": true,
    "incremental": true,
    "mode": "development"
  },
  "native": {
    "prebuilt": false,
    "cmakePreset": "default"
  },
  "dev": {
    "hotReload": true,
    "watchPaths": [
      "./src"
    ],
    "debounceMs": 120
  },
  "module": {
    "prefix": "QmlSharp.DevFlow",
    "version": {
      "major": 1,
      "minor": 0
    }
  }
}
