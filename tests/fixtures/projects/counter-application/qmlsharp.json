{
  "name": "CounterApp",
  "version": "1.0.0",
  "entry": "./src/Program.cs",
  "outDir": "./dist",
  "qt": {
    "dir": "__QT_DIR__",
    "modules": [
      "QtQuick",
      "QtQuick.Controls"
    ]
  },
  "build": {
    "format": true,
    "lint": true,
    "sourceMaps": true,
    "incremental": false,
    "mode": "development"
  },
  "native": {
    "prebuilt": false,
    "cmakePreset": "default"
  },
  "module": {
    "prefix": "QmlSharp.CounterApp",
    "version": {
      "major": 1,
      "minor": 0
    }
  }
}
