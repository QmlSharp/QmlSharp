{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "ENABLE_ASAN": false,
        "ENABLE_CLANG_TIDY": false,
        "USE_WERROR": true
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "FASTBuild",
      "environment": {
        "PATH": "$penv{WindowsKitRC};$penv{PATH}",
        "FASTBUILD_CACHE_PATH": "$penv{LOCALAPPDATA}/FASTBuild/Cache"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "Embedded"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0"
      }
    },
    {
      "name": "macos-fastbuild-base",
      "hidden": true,
      "inherits": ["macos-base"],
      "generator": "FASTBuild"
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "inherits": ["macos-base"],
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": ["macos-base"],
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-ci",
      "displayName": "macOS CI Debug",
      "inherits": ["macos-fastbuild-base"],
      "binaryDir": "${sourceDir}/build/macos-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-fastbuild-base",
      "hidden": true,
      "inherits": ["linux-base"],
      "generator": "FASTBuild"
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": ["linux-base"],
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "inherits": ["linux-base"],
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-ci",
      "displayName": "Linux CI Debug",
      "inherits": ["linux-fastbuild-base"],
      "binaryDir": "${sourceDir}/build/linux-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-ci",
      "displayName": "Windows x64 CI Debug",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/windows-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "windows-debug",
      "displayName": "Windows Debug",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "release",
      "configurePreset": "windows-release",
      "displayName": "Windows Release",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug",
      "displayName": "macOS Debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "displayName": "macOS Release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "displayName": "Linux Debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "displayName": "Linux Release"
    },
    {
      "name": "windows-ci",
      "configurePreset": "windows-ci",
      "displayName": "Windows x64 CI",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "macos-ci",
      "configurePreset": "macos-ci",
      "displayName": "macOS CI",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "linux-ci",
      "configurePreset": "linux-ci",
      "displayName": "Linux CI",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    }
  ]
}
